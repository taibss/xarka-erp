# Xarka ERP — eSSL Biometric Sync Agent Configuration
# =====================================================
# Copy this file to .env and fill in the values.
# Required: XARKA_API_URL, XARKA_API_TOKEN, ESSL_MDB_PATH

# Xarka ERP server URL (no trailing slash)
XARKA_API_URL=https://your-xarka-server.com

# Admin JWT token for API authentication
# Generate via: POST /auth/login with admin credentials
XARKA_API_TOKEN=eyJhbGciOiJIUzI1NiIs...

# Path to eTimeTrackLite MDB file
# Typical: C:\Program Files\eTimeTrackLite\eTimeTrackLite.mdb
ESSL_MDB_PATH=C:\Program Files\eTimeTrackLite\eTimeTrackLite.mdb

# Request timeout in seconds (default: 30)
REQUEST_TIMEOUT=30

# Max retry attempts on transient failures (default: 3)
MAX_RETRIES=3

# Delay between retries in seconds (default: 5)
RETRY_DELAY=5
